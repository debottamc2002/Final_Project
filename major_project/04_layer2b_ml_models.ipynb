    "importance_df.index.name = \"Feature\"\n",
    "\n",
    "importance_df.to_csv(\n",
    "    \"data/layer2b_feature_importance.csv\"\n",
    ")\n",
    "\n",
    "print(\"\\nSaved: data/layer2b_feature_importance.csv\")"
